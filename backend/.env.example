# MongoDB Configuration
MONGO_USER=root
MONGO_PASSWORD=root
MONGO_HOST=127.0.0.1
MONGO_PORT=27017
MONGO_DB=expense_tracker
MONGO_AUTH_SOURCE=admin

# JWT Secret Key (REQUIRED - Change in production!)
